# OpenClaw API (OpenAI-compatible)
OPENCLAW_BASE_URL=https://your-openclaw-domain
OPENCLAW_API_KEY=replace_me
OPENCLAW_MODEL=gpt-4o-mini

# Mail account
MAIL_IMAP_HOST=imap.exmail.qq.com
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=smtp.exmail.qq.com
MAIL_SMTP_PORT=465
MAIL_USERNAME=bot@your-company.com
MAIL_PASSWORD=replace_me
MAIL_USE_SSL=true

# Enterprise WeChat app
WECOM_CORP_ID=wwxxxxxxxxxxxx
WECOM_CORP_SECRET=replace_me
WECOM_AGENT_ID=1000002
WECOM_REPORT_TO=zhangsan|lisi

# Workflow
AUTO_REPLY_ENABLED=false
AUTO_REPLY_PRIORITY=low,normal
REPORT_CRON=0 18 * * 1-5
TZ=Asia/Shanghai

# Runtime
DB_PATH=app/data/openclaw_mail.db
LOG_LEVEL=INFO
