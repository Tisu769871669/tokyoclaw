PORT=9070

# Shared secret for caller authentication.
# Caller should send: Authorization: Bearer <token>
AGENT_BRIDGE_TOKEN=replace_me

# OpenClaw CLI settings
OPENCLAW_BIN=openclaw
DEFAULT_AGENT_ID=snowchuang
AGENT_TIMEOUT_SECONDS=120

# Local FAQ-style knowledge base for lightweight retrieval
KNOWLEDGE_FILE=客服回复优化.txt
KB_TOP_K=3
KB_MIN_SCORE=3

# Bridge-owned session memory. Each agent + conversationId gets isolated history.
SESSION_STORE_DIR=.sessions
SESSION_HISTORY_LIMIT=20

# Friend approval welcome flow. When POST body has status=1, sendId, recvId,
# conversationId, and tenantId, agent-bridge sends this content directly and returns 204.
FRIEND_WELCOME_SEND_URL=https://lx.metast.cn/prod-api/system/api/im/sendWxIdMesage
FRIEND_WELCOME_TEXT=欢迎添加雪创客服
FRIEND_WELCOME_LINK=https://replace_me
FRIEND_WELCOME_SEND_TIMEOUT_MS=10000

# Preferred tenant credential and welcome content map.
# Quote this value in .env when secrets/content contain #, $, &, or spaces.
FRIEND_WELCOME_TENANT_CREDENTIALS={"125":{"mcpKey":"replace_me","mcpSecret":"replace_me","welcomeContent":"欢迎添加雪创客服"}}

# Backward-compatible fallback when tenant-specific credentials are not configured.
FRIEND_WELCOME_MCP_KEY=replace_me
FRIEND_WELCOME_MCP_SECRET=replace_me
